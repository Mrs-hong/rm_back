# 启用的检查列表
Checks:
  # 禁用所有检测
  - "-*"
  # [致命]
  # G.INT.03 确保除法和余数运算不会导致除零错误(被零除)【C】
  - clang-analyzer-core.DivideZero
  # [部分支持] G.STD.17-CPP 禁止调用kill、TerminateProcess函数直接终止其他进程
  - bugprone-bad-signal-to-kill-thread
  # G.OTH.12 禁止对STL等容器使用memcpy系列函数，会使得内存重复释放导致core
  - bugprone-undefined-memory-manipulation
  #- clang-analyzer-core.CallAndMessage
  # [不支持] G.RES.05-CPP 当lambda会逃逸出函数外面时，禁止按引用捕获局部变量
  # - cppcoreguidelines-avoid-default-capture
  # - cppcoreguidelines-avoid-capturing-lambda-coroutines # [部分支持] 支持c++20协程的空lambda
  #
  #
  # [严重]
  # G.INC.09-CPP 头文件中禁止向全局命名空间中导入符号
  - google-build-using-namespace
  # G.INC.10-CPP 不要在头文件中使用匿名namespace或static定义非外部可见符号
  - misc-definitions-in-headers
  # [不生效] G.INT.09 确保枚举常量映射到唯一值
  - clang-diagnostic-duplicate-enum
  # G.PRE.03 包含多条语句的函数式宏的实现语句必须放在 do-while(0) 中
  # G.PRE.02 定义宏时，要使用完备的括号
  - bugprone-macro-parentheses
  - hicpp-multi-statement-macro
  # G.PRE.04 禁止把带副作用的表达式作为参数传递给函数式宏
  - bugprone-macro-repeated-side-effects
  # G.PRE.09 建议定义时就初始化变量，防止未初始化指针被使用
  - cppcoreguidelines-init-variables
  # [非预期效果] G.PRE.10 宏定义不应依赖宏外部的局部变量名
  - clang-diagnostic-error  # 只能检测宏被使用时是否有未定义变量
  # [部分支持] G.PRE.23-CPP 禁止在多线程中使用非线程安全的函数
  - clang-analyzer-security.insecureAPI.*  # 未包含所有的非线程安全函数
  # [非预期效果] G.RES.07-CPP 指向资源句柄或描述符的变量，在资源释放后立即赋予新值
  # - clang-analyzer-core.NullDereference  # 检测空指针使用(但测试并不生效)
  # G.RES.09-CPP 使用std::make_unique 而不是new 创建std::unique_ptr | G.RES.10-CPP 使用std::make_shared 而不是new 创建std::shared_ptr
  - modernize-make-unique
  - modernize-make-shared
  # G.STD.04-CPP 不要保存std::string类型的c_str和data成员函数返回的指针
  - bugprone-dangling-handle
  - clang-analyzer-cplusplus.InnerPointer
  - performance-string-view-conversions
  # G.STD.13-CPP 调用格式化输入/输出函数时，使用有效的格式字符串--格式化类型不匹配
  - clang-diagnostic-format
  - clang-diagnostic-format-security
  - clang-diagnostic-format-invalid-specifier
  # G.STD.16 禁止不同类型的变量直接进行二元运算
  - cppcoreguidelines-narrowing-conversions  # 可能存在精度损失
  # [不生效] G.INT.04 整型表达式比较或赋值为一种更大类型之前必须用这种更大类型对它进行求值【C】
  - bugprone-implicit-widening-of-multiplication-result # 乘法溢出检测
  # [不生效] G.STD.16-CPP 禁用程序与线程的退出函数和atexit函数
  - bugprone-disallowed-functions
  #
  #
  # [一般]
  # G.INC.20-CPP 不要在头文件中使用匿名空间，会增加编译后的二进制大小
  - google-build-namespaces
  # [存在误报，只能用const修饰的全局变量] G.INC.11-CPP 使用命名空间来管理全局函数、全局常量和全局类型
  - cppcoreguidelines-avoid-non-const-global-variables
  # G.INC.07-CPP 按照合理的顺序包含头文件
  - llvm-include-order
  # G.NAM.01 使用统一的命名风格
  - readability-identifier-naming
  # G.OTH.01 删除无效或永不执行的代码
  - clang-analyzer-deadcode.DeadStores
  - misc-unused-parameters
  # G.OTH.03 禁用rand函数产生用于安全用途的伪随机数【C】
  - cert-msc30-c
  # G.OTH.10 STL插入推荐使用emplace_back
  - modernize-use-emplace
  # [不符合预期] G.OTH.11 在使用vector、queue等顺序容器时建议使用变量前设置一个合理的容器大小，避免插入时出现多次扩容
  # - performance-*  # 有太多优化配置，开启容易误报
  # G.OTH.13 针对map、unordered_map在遍历时尽可能使用auto（因为其键值对为<const T, U>, 很容易遗漏const导致复制对象）
  - performance-implicit-conversion-in-loop
  # [存在误报] G.PRE.01-CPP 禁止使用宏来表示常量
  # - cppcoreguidelines-macro-usage  # 只要涉及宏计算相关的都会被误报
  # G.PRE.08 头文件使用宏定义区分来防止重复导入
  - llvm-header-guard
  # G.RES.12-CPP 自定义new/delete操作符需要配对定义，且行为与被替换的操作符一致
  - misc-new-delete-overloads
  # G.STD.01-CPP 使用新的标准头文件
  - modernize-deprecated-headers
  # [不完全符合预期] G.STD.02-CPP 使用std::string表示字符串
  - modernize-avoid-c-arrays
  - cppcoreguidelines-avoid-c-arrays
  # [不生效] G.STD.10-CPP 静态变量定义不使用const，建议使用static constexpr
  - clang-diagnostic-constexpr-not-const
  # [存在误报] G.STD.20-CPP string字符串的追加建议使用append
  # - performance-inefficient-string-concatenation  # 使用 ”+“ 等字符串操作都会误报
  # G.TYP.03 使用合适的类型表示字符【C】
  - bugprone-signed-char-misuse
  # [非预期，只能检测使用值捕获this] G.RES.06-CPP 避免lambda表达式使用默认捕获模式
  - cppcoreguidelines-misleading-capture-default-by-value

  # 成员变量优先使用声明时初始化或者构造函数初始化列表初始化
  - cppcoreguidelines-pro-type-member-init
  # 单参数构造函数声明为explicit
  - google-explicit-constructor
  # 拷贝构造函数和拷贝赋值操作符,移动构造函数和移动赋值操作符应该同时声明
  - cppcoreguidelines-special-member-functions
  # 对象切片检测
  - cppcoreguidelines-slicing
  # 移动操作 noexcept
  - hicpp-noexcept-move
  # 建议使用 noexcept
  - hicpp-use-noexcept
  # 禁止在虚函数中使用缺省参数值
  - google-default-arguments
  # 在重写虚函数时应明确指定override或final
  - cppcoreguidelines-explicit-virtual-functions
  # 禁止使用小写字母“l”作为数值型字面量后缀
  - readability-uppercase-literal-suffix
  # 禁止使用goto
  - cppcoreguidelines-avoid-goto
  # 使用enum class
  - cppcoreguidelines-use-enum-class
  # 异常基类规范
  - hicpp-exception-baseclass
  # 抛值捕引用
  - misc-throw-by-value-catch-by-reference
  # 异常相关诊断
  - clang-diagnostic-exceptions
  # 不要在嵌套作用域中重用名称
  - clang-diagnostic-shadow
  # 使用noexcept声明的构造函数初始化全局和线程局部变量
  - cert-err58-cpp
  # using 替代 typedef
  - modernize-use-using
  # 使用由C++提供的类型转换操作
  - cppcoreguidelines-pro-type-cstyle-cast
  # 限制 reinterpret_cast
  - cppcoreguidelines-pro-type-reinterpret-cast
  # 限制 const_cast
  - cppcoreguidelines-pro-type-const-cast
  # 避免移动 const 参数
  - performance-move-const-arg
  # 简化布尔表达式
  - readability-simplify-boolean-expr
  # 使用 static_assert
  - misc-static-assert
  # 使用 nullptr
  - modernize-use-nullptr
  # switch 缺少 default
  - bugprone-switch-missing-default-case
  # assert 副作用检查
  - bugprone-assert-side-effect
  # TODO 注释规范
  - google-readability-todo
  # 保留标识符检查
  - bugprone-reserved-identifier
  # 分支克隆检测
  - bugprone-branch-clone
  # 变量声明隔离
  - readability-isolate-declaration


  # 提示未修改的指针参数可声明为 const
  - readability-non-const-parameter
  # 识别 owning/raw pointer 语义风险
  - cppcoreguidelines-owning-memory
  # 约束直接使用 malloc/free 等 C 风格内存管理
  - cppcoreguidelines-no-malloc
  # 检测可疑字符串操作（长度/截断/边界）
  - bugprone-suspicious-string-usage
  # 检测 string 构造器误用场景
  - bugprone-string-constructor
  # 检测字面量中嵌入 \0 导致的潜在截断问题
  - bugprone-string-literal-with-embedded-nul
  # 检测危险的动态/静态初始化顺序问题
  - bugprone-dynamic-static-initializers
  # 函数规模检查（行数/参数数/嵌套层级等）
  - readability-function-size
  # 函数认知复杂度检查
  - readability-function-cognitive-complexity
  # 声明与定义的参数命名一致性检查
  - readability-inconsistent-declaration-parameter-name
  # 建议仅本文件使用的符号采用内部链接
  - misc-use-internal-linkage
  # 检测 atoi/atol/atof 等转换风险（CERT ERR34-C）
  - cert-err34-c
  # dup 系列调用建议带 CLOEXEC 语义
  - android-cloexec-dup
  # open/openat 等建议使用 CLOEXEC
  - android-cloexec-open
  # socket 创建建议使用 CLOEXEC
  - android-cloexec-socket
  # epoll_create 建议使用支持 CLOEXEC 的形式
  - android-cloexec-epoll-create
  # pipe 建议使用支持 CLOEXEC 的形式
  - android-cloexec-pipe
  # fopen 建议使用 e 模式（close-on-exec）
  - android-cloexec-fopen
  # creat 建议避免缺失 close-on-exec 风险
  - android-cloexec-creat
  # 禁止 C 风格可变参数（...）
  - cppcoreguidelines-pro-type-vararg
  # C++ 可变参数函数声明约束（CERT DCL50-CPP）
  - cert-dcl50-cpp
  # 检测返回局部对象时不必要的 std::move
  - performance-no-automatic-move
  # 打开编译器诊断，承接无法直接映射的规则
  - clang-diagnostic-*
  - readability-braces-around-statements


# 将所有捕获到的警告视为 Error
WarningsAsErrors: '*'

# 检查所有头文件
HeaderFilterRegex: '.*'

# 识别为头文件的扩展名列表（合并自 test/.clang-tidy）
HeaderFileExtensions: ['h']

# 忽略系统头文件中的警告
SystemHeaders: false

# 不自动格式化
FormatStyle: none

#针对具体规则的额外参数微调
CheckOptions:
  # 指定 include 排序的风格
  - key: llvm-include-order.IncludeStyle
    value: llvm  # 使用LLVM风格的include排序

  - key: modernize-make-unique.IgnoreMacros
    value: false

  - key: modernize-make-shared.IgnoreMacros
    value: false
  # [不生效] 指定函数禁止(G.STD.16-CPP 禁用程序与线程的退出函数和atexit函数)
  - key: bugprone-disallowed-functions.DisallowedFunctions
    value: 'std::exit;exit;_Exit;quick_exit;atexit;std::atexit;kill;TerminateProcess'

  # G.PRE.02 定义宏时，要使用完备的括号
  - key: bugprone-macro-parentheses.StrictMode
    value: true

  - key: llvm-header-guard.HeaderFileExtensions
    value: 'h'

  # G.STD.10-CPP 静态变量定义不使用const，建议使用static constexpr
  - key: modernize-use-constexpr.MinTypeNameLength
    value: 0

  # G.STD.20-CPP string字符串的追加建议使用append
  - key: performance-inefficient-string-concatenation.WarnOnLargeObject
    value: true


  # 强制 if/for/while 等短语句也必须使用大括号（0 表示不允许省略）
  - key: readability-braces-around-statements.ShortStatementLines
    value: '0'
  # 宏定义名称使用全大写风格
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  # 类名使用 CamelCase
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  # 函数名使用 CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  # 局部变量使用 camelBack 风格
  - key: readability-identifier-naming.LocalVariableCase
    value: camelBack
  # 成员变量使用 CamelCase 风格
  - key: readability-identifier-naming.PrivateMemberCase
    value: CamelCase
  # 成员变量统一使用 m 前缀
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: m
  # 全局常量使用 CamelCase
  - key: readability-identifier-naming.GlobalConstantCase
    value: CamelCase
  # 静态变量使用 CamelCase
  - key: readability-identifier-naming.StaticVariableCase
    value: CamelCase
  # make_unique 检查忽略自定义分配器场景
  - key: modernize-make-unique.IgnoreCustomAllocators
    value: 'true'
  # owning-memory 检查允许类型白名单（空表示不额外放行）
  - key: cppcoreguidelines-owning-memory.AllowedTypes
    value: ''
  # owning-memory 大对象阈值（字节）
  - key: cppcoreguidelines-owning-memory.LargeObjectThreshold
    value: '16'
  # 函数参数数量阈值
  - key: readability-function-size.ParameterThreshold
    value: '4'
  # 函数行数阈值
  - key: readability-function-size.LineThreshold
    value: '50'
  # 函数嵌套层级阈值
  - key: readability-function-size.NestingThreshold
    value: '4'
  # 认知复杂度阈值
  - key: readability-function-cognitive-complexity.Threshold
    value: '15'
  # 认知复杂度诊断中输出基础增量细节
  - key: readability-function-cognitive-complexity.DescribeBasicIncrements
    value: 'true'
  # 可疑字符串操作：开启隐式窄化告警
  - key: bugprone-suspicious-string-usage.WarnOnImplicitNarrowing
    value: 'true'
  # 可疑字符串操作：开启长度不足告警
  - key: bugprone-suspicious-string-usage.WarnOnInsufficientSize
    value: 'true'
  # 建议使用匿名命名空间作为内部链接修复方式
  - key: misc-use-internal-linkage.UseAnonymousNamespace
    value: 'true'
  # 忽略名称匹配该正则的符号（如以下划线开头）
  - key: misc-use-internal-linkage.IgnoreNames
    value: '^_*'
